# ============================================================
# NXTUP — variables de entorno
# Copia a .env.local (local) / configura en Vercel (producción).
# NUNCA commitear valores reales. Ver OPERATIONS.md para contexto.
# ============================================================

# ── Supabase (requeridas para bootear) ───────────────────────
# Dashboard de Supabase → Settings → API (proyecto wxrlhpjiyqnjuujjcozm)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key>

# Service role — SOLO server-side (admin client, bypassa RLS).
# Sin ella: la app arranca pero fallan kiosko, webhooks y demo-reset.
SUPABASE_SERVICE_ROLE_KEY=<service role key>

# ── Dispositivos (NXT TAP / paneles) ─────────────────────────
# Token que mandan los dispositivos en el header x-device-token para
# /api/barbers/[id]/state y /snapshot.
DEVICE_API_TOKEN=<token largo aleatorio>

# ── Integración Mamacita / Julie (voz) ───────────────────────
# Secreto compartido con Mamacita: Bearer + firma HMAC-SHA256 del body
# en ambas direcciones (src/lib/mamacita.ts). Debe ser IDÉNTICO al que
# tiene Mamacita configurado.
MAMACITA_SHARED_SECRET=<secreto compartido>
# A dónde NXTUP le manda eventos a Mamacita (entry_completed, etc.).
MAMACITA_WEBHOOK_URL=https://<mamacita>/api/nxtup/webhook

# ── Acceso admin/socios ──────────────────────────────────────
# Emails (separados por coma) con acceso a /admin sin ser dueños de shop.
ADMIN_EMAILS=admin@ejemplo.com
PARTNER_EMAILS=socio1@ejemplo.com,socio2@ejemplo.com

# ── Misc ─────────────────────────────────────────────────────
# Base URL para links generados server-side (panel tokens).
NEXT_PUBLIC_SITE_URL=https://www.getnxtup.com

# ── Stripe (rama feat/stripe-billing — aún sin desplegar) ────
# Test mode primero (sk_test_...); live cuando haya EIN + banco.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   # del endpoint /api/stripe/webhook
# STRIPE_PRICE_PRO=price_...        # Price id del plan (precios por definir)
