// ============================================================
// secrets.h.example — COPY THIS FILE TO secrets.h AND FILL IN
//
//   cp include/secrets.h.example include/secrets.h
//
// secrets.h is gitignored — never commit your real values.
// ============================================================

#pragma once

// ── WiFi credentials of the shop ──────────────────────────────
#define WIFI_SSID       "your-wifi-name"
#define WIFI_PASSWORD   "your-wifi-password"

// ── Identity ──────────────────────────────────────────────────
// Get the shop_id from the dashboard (Sesión card on the homepage,
// or any URL like /dashboard).
//
// Get the barber_id by clicking on a barber's button on the homepage
// (the URL becomes /barber/[shop_id]/[barber_id] — copy the second UUID).
#define SHOP_ID         "00000000-0000-0000-0000-000000000000"
#define BARBER_ID       "00000000-0000-0000-0000-000000000000"

// ── Device API token ──────────────────────────────────────────
// Must match BOTH:
//   * the DEVICE_API_TOKEN env var in Vercel (legacy path, still used
//     for the snapshot endpoint until full migration), AND
//   * the value stored in Supabase app_settings.device_api_token
//     (used by the new device-direct RPCs from migration 017).
#define DEVICE_API_TOKEN  "nxtap_REPLACE_ME"

// ── Backend host ──────────────────────────────────────────────
// Legacy Vercel path. The Vercel endpoints remain available for the
// web app (owner/barber browsers). The device itself now talks
// directly to Supabase for its hot path — see SUPABASE_* below.
#define NXTUP_HOST      "getnxtup.com"

// ── Supabase direct (the device's hot path) ───────────────────
// Migration 017 moved the device off Vercel to cut tap→TV latency
// from ~15s to ~500ms. The firmware now POSTs directly to:
//
//   https://<SUPABASE_HOST>/rest/v1/rpc/device_update_barber_state
//   https://<SUPABASE_HOST>/rest/v1/rpc/device_get_barber_snapshot
//
// SUPABASE_HOST is the project ref + ".supabase.co" — e.g.
// "abcdefghijklmnopqrst.supabase.co". You can find it in Supabase
// dashboard → Project Settings → API → Project URL (drop the
// https:// prefix).
#define SUPABASE_HOST   "your-project-ref.supabase.co"

// The PUBLIC anon key. Safe to embed in firmware — it's the same key
// the browser app uses. RLS + the device_api_token gate the actual
// device functions; the anon key is just the ticket to call them.
// Get it from Supabase dashboard → Project Settings → API → anon public.
#define SUPABASE_ANON_KEY "eyJ_REPLACE_ME"
