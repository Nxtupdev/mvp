//
//   cp include/secrets.h.example include/secrets.h
//
// secrets.h is gitignored — never commit your real values.
// ============================================================

#pragma once

// ── WiFi credentials of the shop ──────────────────────────────
#define WIFI_SSID       "your-wifi-name"
#define WIFI_PASSWORD   "your-wifi-password"

// ── Identity ──────────────────────────────────────────────────
// Get the shop_id from the dashboard (Sesión card on the homepage,
// or any URL like /dashboard).
//
// Get the barber_id by clicking on a barber's button on the homepage
// (the URL becomes /barber/[shop_id]/[barber_id] — copy the second UUID).
#define SHOP_ID         "00000000-0000-0000-0000-000000000000"
#define BARBER_ID       "00000000-0000-0000-0000-000000000000"

// ── Device API token ──────────────────────────────────────────
// Must match the DEVICE_API_TOKEN env var you set in Vercel.
#define DEVICE_API_TOKEN  "nxtap_REPLACE_ME"

// ── Backend host ──────────────────────────────────────────────
// Change this to a staging URL or local IP if you're not hitting prod.
#define NXTUP_HOST      "getnxtup.com"
